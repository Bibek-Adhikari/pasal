# NEXT_PUBLIC_GOOGLE_MAPS_EMBED_API_KEY: Optional. For satellite view in contact map.
# Get from Google Cloud Console > APIs > Maps Embed API. Without this, a standard embed is used.
# NEXT_PUBLIC_GOOGLE_MAPS_EMBED_API_KEY="YOUR_MAPS_EMBED_API_KEY"

# GEMINI_API_KEY: Fallback. For Gemini AI API calls if Groq fails.
# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# GROQ_API_KEY: Primary. For faster Groq AI API calls.
# Get from https://console.groq.com/keys
GROQ_API_KEY="YOUR_GROQ_API_KEY"

# TTS_API_KEY: Optional. For Text-to-Speech API (OpenAI-compatible).
# Get from https://serveai.chat or other TTS service providers.
# Without this, browser-native Web Speech API will be used.
TTS_API_KEY="YOUR_TTS_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
